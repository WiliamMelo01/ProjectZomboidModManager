{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PZ Manager",
  "version": "0.1.0",
  "identifier": "com.wiliammelo.zomboidservermodmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PZ Manager",
        "width": 1200,
        "height": 800
      }
    ]
  },
  "bundle": {
    "targets": [
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/server-example",
      "../resources/steacmd/steamcmd.zip"
    ]
  }
}
